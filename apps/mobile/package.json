    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint": "latest",
    "eslint-config-expo": "latest",
    "jest": "latest",
    "jest-expo": "latest",
    "typescript": "latest"
  }
